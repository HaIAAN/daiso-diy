#!/usr/bin/env python3
"""
다이소 홈페이지 제품 크롤러
실행: python scripts/crawl_daiso.py
결과: products.json 파일을 루트에 생성
"""

import json
import time
import random
import re
import sys
from datetime import datetime
from urllib.request import urlopen, Request
from urllib.error import URLError, HTTPError
from html.parser import HTMLParser

# ── 설정 ──────────────────────────────────────────────────────────────────────
BASE_URL = "https://www.daiso.co.kr"

# 크롤링할 카테고리 목록 (다이소 카테고리 코드)
CATEGORIES = [
    {"name": "생활용품",     "code": "10000"},
    {"name": "주방",         "code": "10001"},
    {"name": "문구/완구",    "code": "10002"},
    {"name": "뷰티",         "code": "10003"},
    {"name": "식품",         "code": "10004"},
    {"name": "인테리어",     "code": "10005"},
    {"name": "원예",         "code": "10006"},
    {"name": "전기/전자",    "code": "10007"},
    {"name": "스포츠/레저",  "code": "10008"},
    {"name": "반려동물",     "code": "10009"},
]

HEADERS = {
    "User-Agent": (
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
        "AppleWebKit/537.36 (KHTML, like Gecko) "
        "Chrome/120.0.0.0 Safari/537.36"
    ),
    "Accept-Language": "ko-KR,ko;q=0.9",
    "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
}

MAX_PRODUCTS_PER_CAT = 20   # 카테고리당 최대 수집 개수
DELAY_MIN = 1.0              # 요청 사이 최소 대기 (초) — 서버 부하 방지
DELAY_MAX = 2.5              # 요청 사이 최대 대기 (초)
OUTPUT_PATH = "products.json"


# ── HTML 파서 ─────────────────────────────────────────────────────────────────
class ProductListParser(HTMLParser):
    """다이소 상품 목록 페이지에서 제품 정보를 추출"""

    def __init__(self):
        super().__init__()
        self.products = []
        self._in_item = False
        self._current = {}
        self._capture = None

    def handle_starttag(self, tag, attrs):
        attrs = dict(attrs)

        # 상품 카드 컨테이너 감지
        cls = attrs.get("class", "")
        if tag == "li" and "prd-item" in cls:
            self._in_item = True
            self._current = {}

        if not self._in_item:
            return

        # 상품 링크 & ID
        if tag == "a" and "href" in attrs and "goodsDetailView" in attrs.get("href", ""):
            m = re.search(r"goodsNo=(\d+)", attrs["href"])
            if m:
                self._current["id"] = "P" + m.group(1)

        # 상품 이미지
        if tag == "img" and "src" in attrs and not self._current.get("image"):
            src = attrs["src"]
            if src.startswith("//"):
                src = "https:" + src
            if "/goods/" in src or "product" in src.lower():
                self._current["image"] = src

        # 가격 span
        if tag == "span" and "price" in cls:
            self._capture = "price"

        # 상품명 p or span
        if tag in ("p", "span") and "name" in cls:
            self._capture = "name"

    def handle_data(self, data):
        data = data.strip()
        if not data or not self._in_item:
            return
        if self._capture == "price":
            cleaned = re.sub(r"[^\d]", "", data)
            if cleaned:
                self._current["price"] = int(cleaned)
            self._capture = None
        elif self._capture == "name":
            if data:
                self._current["name"] = data
            self._capture = None

    def handle_endtag(self, tag):
        if tag == "li" and self._in_item:
            self._in_item = False
            p = self._current
            # 필수 필드가 있는 경우만 저장
            if p.get("name") and p.get("id"):
                if "price" not in p:
                    p["price"] = 1000   # 기본 다이소 가격
                self.products.append(p)
            self._current = {}


# ── 크롤링 함수 ───────────────────────────────────────────────────────────────
def fetch_html(url: str) -> str | None:
    """지정 URL의 HTML을 가져옴. 실패 시 None 반환."""
    try:
        req = Request(url, headers=HEADERS)
        with urlopen(req, timeout=15) as resp:
            return resp.read().decode("utf-8", errors="replace")
    except (URLError, HTTPError) as e:
        print(f"  ⚠️  요청 실패: {url} → {e}", file=sys.stderr)
        return None


def crawl_category(cat_code: str, cat_name: str) -> list[dict]:
    """카테고리 코드로 상품 목록 수집"""
    products = []
    page = 1

    while len(products) < MAX_PRODUCTS_PER_CAT:
        url = (
            f"{BASE_URL}/goods/goodsList.do"
            f"?cateCd={cat_code}&pageIndex={page}&pageUnit=20"
            f"&sortType=NEW"
        )
        print(f"  📄 페이지 {page}: {url}")
        html = fetch_html(url)

        if not html:
            break

        parser = ProductListParser()
        parser.feed(html)
        page_products = parser.products

        if not page_products:
            # 상품이 없으면 마지막 페이지
            break

        for p in page_products:
            p["category"] = cat_name
            if not p.get("image"):
                # 이미지 없으면 기본 Pollinations 이미지로 대체
                query = p["name"].replace(" ", "%20")
                seed = hash(p["id"]) % 9000 + 1000
                p["image"] = (
                    f"https://image.pollinations.ai/prompt/daiso%20{query}"
                    f"%20product%20photo%20white%20background"
                    f"?width=200&height=200&seed={seed}&nologo=true"
                )
            products.append(p)

        if len(products) >= MAX_PRODUCTS_PER_CAT:
            products = products[:MAX_PRODUCTS_PER_CAT]
            break

        page += 1
        time.sleep(random.uniform(DELAY_MIN, DELAY_MAX))

    return products


def deduplicate(products: list[dict]) -> list[dict]:
    """ID 기준 중복 제거"""
    seen = set()
    result = []
    for p in products:
        if p["id"] not in seen:
            seen.add(p["id"])
            result.append(p)
    return result


# ── 메인 ─────────────────────────────────────────────────────────────────────
def main():
    print(f"\n🛒 다이소 제품 크롤링 시작 — {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")

    all_products = []

    for cat in CATEGORIES:
        print(f"📦 [{cat['name']}] 카테고리 수집 중...")
        try:
            products = crawl_category(cat["code"], cat["name"])
            print(f"  ✅ {len(products)}개 수집 완료")
            all_products.extend(products)
        except Exception as e:
            print(f"  ❌ 수집 실패: {e}", file=sys.stderr)

        time.sleep(random.uniform(DELAY_MIN, DELAY_MAX))

    all_products = deduplicate(all_products)

    # 크롤링 결과가 너무 적으면 폴백 없이 실패 처리
    if len(all_products) < 5:
        print("\n⚠️  수집된 제품이 너무 적습니다. 다이소 사이트 구조가 변경되었을 수 있습니다.")
        print("   기존 products.json을 유지하거나 수동으로 확인해주세요.")
        sys.exit(1)

    # 메타 정보 추가
    output = {
        "updated_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "total": len(all_products),
        "products": all_products
    }

    # 이전 버전과 호환: products 키 없이 배열로도 저장
    # (index.html이 배열을 기대하므로 배열만 저장)
    with open(OUTPUT_PATH, "w", encoding="utf-8") as f:
        json.dump(all_products, f, ensure_ascii=False, indent=2)

    print(f"\n✅ 크롤링 완료! 총 {len(all_products)}개 제품 → {OUTPUT_PATH}")
    print(f"   업데이트 시각: {output['updated_at']}\n")


if __name__ == "__main__":
    main()
